generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ============ USER & AUTH MODELS ============
// Role values: STUDENT | ACADEMIC_STAFF | COUNSELOR | MAINTENANCE | CAMPUS_MARSHAL | ADMIN

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          String    @default("STUDENT")
  phone         String?
  department    String?
  studentId     String?   @unique
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]

  // Student relations
  ticketsCreated    Ticket[]       @relation("TicketCreator")
  appointments      Appointment[]  @relation("AppointmentStudent")
  notifications     Notification[]

  // Staff relations
  ticketsAssigned   Ticket[]       @relation("TicketAssignee")
  appointmentsStaff Appointment[]  @relation("AppointmentStaff")
  ticketNotes       TicketNote[]
  announcements     Announcement[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============ TICKET & CASE MANAGEMENT ============
// category: ACADEMIC_SUPPORT | COUNSELING | CAMPUS_ISSUE | CAMPUS_SAFETY | RAGGING | MAINTENANCE | OTHER
// status: OPEN | IN_PROGRESS | RESOLVED | CLOSED | ESCALATED
// priority: LOW | MEDIUM | HIGH | URGENT

model Ticket {
  id          String   @id @default(cuid())
  title       String
  description String
  category    String
  status      String   @default("OPEN")
  priority    String   @default("MEDIUM")
  isAnonymous Boolean  @default(false)

  createdById String
  createdBy   User     @relation("TicketCreator", fields: [createdById], references: [id])

  assignedToId String?
  assignedTo   User?   @relation("TicketAssignee", fields: [assignedToId], references: [id])

  notes       TicketNote[]
  attachments TicketAttachment[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("tickets")
}

model TicketNote {
  id       String  @id @default(cuid())
  content  String
  isPublic Boolean @default(true)

  ticketId String
  ticket   Ticket  @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  authorId String
  author   User    @relation(fields: [authorId], references: [id])

  createdAt DateTime @default(now())

  @@map("ticket_notes")
}

model TicketAttachment {
  id       String  @id @default(cuid())
  url      String
  filename String
  mimeType String?

  ticketId String
  ticket   Ticket  @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("ticket_attachments")
}

// ============ APPOINTMENTS ============
// status: PENDING | CONFIRMED | CANCELLED | COMPLETED

model Appointment {
  id        String   @id @default(cuid())
  title     String
  reason    String
  date      DateTime
  time      String
  status    String   @default("PENDING")

  studentId String
  student   User     @relation("AppointmentStudent", fields: [studentId], references: [id])

  staffId   String
  staff     User     @relation("AppointmentStaff", fields: [staffId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("appointments")
}

// ============ ANNOUNCEMENTS ============
// type: GENERAL | ACADEMIC | SAFETY | EVENT | EMERGENCY

model Announcement {
  id        String  @id @default(cuid())
  title     String
  content   String
  type      String  @default("GENERAL")
  isActive  Boolean @default(true)

  authorId  String
  author    User    @relation(fields: [authorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("announcements")
}

// ============ NOTIFICATIONS ============

model Notification {
  id      String  @id @default(cuid())
  title   String
  message String
  isRead  Boolean @default(false)
  link    String?

  userId  String
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("notifications")
}
